  "require": {
    "php": ">=8.0"
  },
  "autoload": {
    "psr-4": {
      "FrontTheme\\SimplePostLike\\": "includes/classes/",
      "FrontTheme\\SimplePostLike\\Traits\\": "includes/traits/"
    }
